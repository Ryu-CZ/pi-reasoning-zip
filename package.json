    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "pi": {
    "extensions": ["dist/index.js"]
  }
}
