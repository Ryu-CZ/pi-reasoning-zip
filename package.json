{
  "name": "pi-reasoning-zip",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md", "DESIGN.md", "IMPLEMENTATION_PLAN.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
